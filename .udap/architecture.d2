# udap:meta cloud=aws region=us-east-1 target=ec2

user: User { shape: rectangle; udap-type: generic.user }
vpc: Default VPC {
  ec2: Web Server (EC2 t3.micro) { shape: rectangle; udap-type: aws.ec2 }
}

user -> vpc.ec2: HTTP :80
vpc.ec2 -> vpc.ec2: Django App\n(Gunicorn :8000)
vpc.ec2 -> vpc.ec2: SQLite DB\n(local file)
